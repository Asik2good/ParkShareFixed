PORT=3000

# Сгенерируй случайную строку:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_long_random_string

# Twilio — регистрация на twilio.com (триал даёт ~15$)
# Account SID и Auth Token — на главной странице Console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Номер из раздела Phone Numbers → Manage → Active numbers
TWILIO_PHONE_NUMBER=+1234567890

# true  — реально слать SMS через Twilio
# false — просто выводить код в консоль (для разработки)
SMS_REAL=false
